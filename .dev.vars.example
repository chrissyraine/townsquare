# Copy to .dev.vars (gitignored) for local `wrangler pages dev dist`.
# In production these are set as Cloudflare Pages secrets (see wrangler.toml).

# TownSquare's OWN session-signing secret (any long random string).
SESSION_SECRET="dev-townsquare-session-secret-change-me"

# Each product's EXISTING SESSION_SECRET, so the broker can mint product-native
# tokens. Pull each from that product's Cloudflare Pages secrets / .dev.vars.
HERALD_SECRET="<Herald SESSION_SECRET>"
DRAWBRIDGE_SECRET="<Drawbridge SESSION_SECRET>"
BELLTOWER_SECRET="<Belltower SESSION_SECRET>"
HEARTH_SECRET="<Hearth SESSION_SECRET>"

# Listing-claim flow (Phase 2 Part B). Both optional in dev:
# - Without RESEND_API_KEY, claim-start still queues the claim (sendEmail no-ops).
# - OTP_DEV_ECHO=1 echoes the raw OTP code back in claim-start's JSON response so
#   local/integration testing doesn't need a real inbox. NEVER set in production.
RESEND_API_KEY=""
EMAIL_DOMAIN="foreverstillstudio.com"
OTP_DEV_ECHO="1"
